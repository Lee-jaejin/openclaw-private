# Copy to .env and fill in real values. Do not commit .env.
OPENCLAW_GATEWAY_TOKEN=replace-me

# OpenClaw 버전 (컨테이너 빌드 시 사용)
OPENCLAW_VERSION=2026.2.15

# Headscale/Tailscale
# 이 장비의 LAN IP (인증서 생성 및 headscale server_url에 사용)
# 예: 192.168.0.10
HEADSCALE_HOST_IP=
HEADSCALE_URL=https://headscale.local:8080
# 예: 100.64.0.10 또는 exit-node.openclaw.private
TAILSCALE_EXIT_NODE=
# 기본값은 false, 공유기 사용하면서 exit node 도 같이 사용하려면 true 로 설정
TAILSCALE_ALLOW_LAN_ACCESS=false

# Ollama 접속 설정
# 호스트 Ollama 사용 시 (기본):
OLLAMA_HOST=http://host.containers.internal:11434
OLLAMA_BASE_URL=http://host.containers.internal:11434/v1
# 컨테이너 Ollama 사용 시 (--profile with-ollama):
# OLLAMA_HOST=http://ollama:11434
# OLLAMA_BASE_URL=http://ollama:11434/v1

# Jetson 등 원격 Ollama 사용 시 (Tailscale tailnet 이름 또는 IP):
# OLLAMA_HOST=http://JETSON_TAILNET_NAME:11434
# OLLAMA_BASE_URL=http://JETSON_TAILNET_NAME:11434/v1
# OPENCLAW_NO_PROXY에 Jetson 호스트명 추가 필요 (예: ...,jetson-device)

# Local auth placeholder for Ollama
OLLAMA_API_KEY=ollama-local

# OpenClaw egress proxy (HTTP/HTTPS)
OPENCLAW_EGRESS_PROXY=http://egress-proxy:3128
# Ollama가 Jetson 등 tailnet 호스트일 경우 해당 호스트명을 끝에 추가
OPENCLAW_NO_PROXY=localhost,127.0.0.1,host.containers.internal,ollama,headscale,egress-proxy

# iMessage SSH bridge (호스트 macOS 사용자명)
IMSG_SSH_USER=

# Egress audit report window (minutes)
AUDIT_WINDOW_MINUTES=60

# Agent Guide 경로 (신규 프로젝트 CLAUDE.md 생성 및 기존 파일 수정 시 참조)
# ~ 사용 불가, 절대경로 필요. 예: /Users/yourname/Study/ai/agent-guide
AGENT_GUIDE_PATH=

# Ralph (Podman + Claude Code subscription 기반 장시간 에이전트 루프)
# claude.ai Pro/Max 구독으로 로그인 후 사용 가능 (API 키 불필요)
# 로그인: pnpm ralph:login
# Podman 이미지 이름 (기본값: ralph-claude)
RALPH_IMAGE=ralph-claude

# Dex OIDC — iPhone headscale VPN 등록용 (선택 사항, Option A)
# DEX_ENABLED=false 시 setup-dex.sh 스킵 → Option B (LAN에서만 ntfy 접근)
DEX_ENABLED=true
# Dex 관리자 계정 (admin@openclaw.private 로 로그인)
DEX_ADMIN_PASSWORD=
# headscale ↔ Dex 공유 시크릿 (랜덤 문자열 권장)
# 생성: openssl rand -hex 24
DEX_CLIENT_SECRET=

# Ralph ntfy 양방향 연동 (선택 사항)
# 설정하면 DECIDE/BLOCKED 시 ntfy 알림 발송, 앱에서 답장으로 ralph 재개 가능
# ntfy는 이 머신(컨트롤 타워)에서 실행: pnpm ntfy:up
# pnpm ralph:watch 를 백그라운드에서 실행해야 양방향 동작
NTFY_URL=http://localhost:8095
NTFY_RALPH_TOPIC=ralph
NTFY_RALPH_REPLY_TOPIC=ralph-reply
NTFY_RALPH_TASK_TOPIC=ralph-task

# Ralph 태스크 대상 프로젝트 디렉토리 (ralph:task-watch에서 tasks.json 위치 결정)
# 예: /Users/yourname/projects/my-project
RALPH_PROJECT_DIR=

# Ralph 신규 프로젝트 생성 기능 (iPhone → ntfy → 프로젝트 스캐폴딩 + GitHub 연동)
# 신규 프로젝트를 생성할 기본 디렉토리 (필수 — 미설정 시 new-project 기능 비활성)
RALPH_PROJECTS_BASE_DIR=
# GitHub 계정/조직명 (선택 사항 — 설정 시 gh CLI로 private repo 자동 생성 및 push)
# 요구사항: gh CLI 설치 + gh auth login 완료
# 예: your-username  또는  your-org-name
GITHUB_OWNER=
# 신규 프로젝트 요청 수신 ntfy 토픽 (기본값: ralph-new-project)
NTFY_RALPH_NEW_PROJECT_TOPIC=ralph-new-project
