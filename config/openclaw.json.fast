{
  "messages": {
    "ackReactionScope": "group-mentions",
    "inbound": {
      "byChannel": {
        "imessage": 5000
      }
    }
  },
  "agents": {
    "defaults": {
      "skipBootstrap": true,
      "model": {
        "primary": "ollama/llama3.1:8b",
        "fallbacks": [
          "ollama/llama3.2:3b"
        ]
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "compaction": {
        "mode": "safeguard"
      },
      "workspace": "/home/node/.openclaw/workspace"
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "${OLLAMA_BASE_URL}",
        "apiKey": "${OLLAMA_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "llama3.1:8b",
            "name": "llama3.1:8b"
          },
          {
            "id": "llama3.2:3b",
            "name": "llama3.2:3b"
          },
          {
            "id": "qwen2.5:7b",
            "name": "qwen2.5:7b"
          },
          {
            "id": "qwen2.5-coder:7b",
            "name": "qwen2.5-coder:7b"
          },
          {
            "id": "phi3:medium",
            "name": "phi3:medium"
          },
          {
            "id": "phi4:14b",
            "name": "phi4:14b"
          }
        ]
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "channels": {
    "imessage": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "groupPolicy": "allowlist"
    }
  },
  "plugins": {
    "entries": {
      "imessage": {
        "enabled": true
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}",
      "rateLimit": {
        "maxAttempts": 10,
        "windowMs": 60000,
        "lockoutMs": 300000,
        "exemptLoopback": true
      }
    },
    "port": 18789,
    "bind": "tailnet",
    "tailscale": {
      "mode": "serve",
      "resetOnExit": true
    }
  },
  "wizard": {},
  "meta": {}
}
