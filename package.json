{
  "name": "openclaw-private",
  "version": "0.1.0",
  "description": "My private OpenClaw setup for closed-circuit networks. Personal use only.",
  "type": "module",
  "scripts": {
    "start": "bash scripts/start.sh",
    "stop": "bash scripts/stop.sh",
    "setup": "bash scripts/setup-all.sh",
    "backup": "bash scripts/backup.sh",
    "monitor": "bash scripts/monitor.sh",
    "health": "set -a && . .env && set +a && bash scripts/health-check.sh",
    "exit-node:on": "bash scripts/route-via-exit-node.sh",
    "exit-node:off": "bash scripts/exit-node-off.sh",
    "route:exit-node": "bash scripts/route-via-exit-node.sh",
    "audit:egress": "bash scripts/audit-egress.sh",
    "audit:cron": "bash scripts/setup-audit-cron.sh",
    "env:watch": "bash scripts/watch-env.sh",
    "ca:gen": "bash scripts/setup-certs.sh",
    "ca:setup": "sudo bash scripts/setup-macos-ca.sh",
    "ca:serve": "bash scripts/serve-ca.sh",
    "docs:dev": "pnpm --filter website start",
    "docs:build": "pnpm --filter website build",
    "docs:serve": "pnpm --filter website serve",
    "ralph": "bash infra/ralph/ralph.sh",
    "ralph:watch": "bash scripts/ralph-imsg-watch.sh",
    "ralph:task-watch": "bash scripts/ralph-task-watch.sh",
    "ralph:start-projects": "bash scripts/ralph-start-projects.sh",
    "ralph:new-project-watch": "bash scripts/ralph-new-project-watch.sh",
    "ralph:new-project": "bash scripts/ralph-new-project.sh",
    "ralph:build": "podman build -t ralph-claude -f infra/ralph/Containerfile infra/ralph",
    "ralph:login": "podman run --rm -it --userns=keep-id -e HOME=/tmp/claude-home -v \"$HOME/.claude:/tmp/claude-home/.claude\" -v \"$HOME/.claude.json:/tmp/claude-home/.claude.json\" ralph-claude login",
    "ntfy:up": "podman compose -f infra/ntfy/docker-compose.yml up -d",
    "ntfy:down": "podman compose -f infra/ntfy/docker-compose.yml down",
    "dex:setup": "bash scripts/setup-dex.sh",
    "dex:up": "podman compose -f infra/dex/docker-compose.yml up -d",
    "dex:down": "podman compose -f infra/dex/docker-compose.yml down",
    "update:openclaw": "bash scripts/update-openclaw.sh"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "private": true
}
